# Neon PostgreSQL (required in production — set in Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth (required in production — set in Vercel)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# OpenAI (optional — AI planner shows a hint if empty)
OPENAI_API_KEY=""

# Set to false to require login again (JWT + middleware)
DISABLE_AUTH="true"
NEXT_PUBLIC_DISABLE_AUTH="true"
