# Neon PostgreSQL (required in production — set in Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth (required in production — set in Vercel)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# OpenAI (optional — AI planner returns 503 if empty)
OPENAI_API_KEY=""
